{
  "name": "unplugin-plugin-userscript",
  "version": "0.3.1",
  "description": "Unplugin plugins for userscript engines",
  "repository": "https://github.com/EnergoStalin/unplugin-plugin-userscript",
  "type": "module",
  "exports": {
    ".": {
      "default": "./build/index.cjs",
      "require": "./build/index.cjs",
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    },
    "./rolldown": {
      "default": "./build/rolldown.cjs",
      "require": "./build/rolldown.cjs",
      "types": "./build/rolldown.d.ts",
      "import": "./build/rolldown.js"
    }
  },
  "keywords": [
    "unplugin",
    "plugin",
    "userscript",
    "tampermonkey",
    "greasymonkey",
    "violentmonkey"
  ],
  "author": "energostalin",
  "license": "ISC",
  "files": [
    "build",
    "readme.md"
  ],
  "scripts": {
    "build:bundle": "tsdown",
    "build": "pnpm lint && pnpm build:bundle",
    "lint:eslint": "eslint src",
    "lint:tsc": "tsc",
    "lint": "pnpm lint:tsc && pnpm lint:eslint",
    "prepublishOnly": "pnpm build",
    "release": "pnpm version -m 'chore(release): %s' --",
    "postversion": "git push && git push --tags",
    "lint:fix": "eslint src --fix"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@types/common-tags": "^1.8.4",
    "@types/node": "^26.1.0",
    "eslint": "^8.54.0",
    "eslint-kit": "^10.6.0",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-require-node-import-prefix": "^0.0.2",
    "prettier": "^3.9.4",
    "tsdown": "^0.22.3"
  },
  "dependencies": {
    "common-tags": "^1.8.2",
    "unplugin": "^3.3.0"
  },
  "volta": {
    "node": "24.18.0"
  }
}
